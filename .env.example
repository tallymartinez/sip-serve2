# Supabase
# Project URL from Supabase -> Settings -> API Keys or Connect
SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (or legacy anon key) from Supabase -> Settings -> API Keys
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret server key (or legacy service_role key) from Supabase -> Settings -> API Keys
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# The short project ref from your Supabase URL, e.g. abcdefghijklmnop
VITE_SUPABASE_PROJECT_ID=your-project-ref
# Same value as SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Same value as SUPABASE_URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Set to true to run the app locally with mock auth and mock data
VITE_DEMO_MODE=false

# Stripe
# Client publishable key used by the browser; test keys usually start with pk_test_
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_xxx
# Secret server key for Stripe test mode
STRIPE_SANDBOX_API_KEY=sk_test_xxx
# Secret server key for Stripe live mode
STRIPE_LIVE_API_KEY=sk_live_xxx
# Webhook secret for Stripe test mode
PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_test_xxx
# Webhook secret for Stripe live mode
PAYMENTS_LIVE_WEBHOOK_SECRET=whsec_live_xxx
# Optional Stripe Price lookup keys if you want names other than the app defaults
# Defaults are: velvet_founding_monthly, velvet_charter_monthly, velvet_member_monthly
STRIPE_FOUNDING_LOOKUP_KEY=velvet_founding_monthly
STRIPE_CHARTER_LOOKUP_KEY=velvet_charter_monthly
STRIPE_MEMBER_LOOKUP_KEY=velvet_member_monthly
